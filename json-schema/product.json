{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.nhtsa.gov/schemas/Product.json",
  "title": "Product",
  "description": "NHTSA Product schema",
  "properties": {
    "artemisCreateDate": {
      "format": "date",
      "type": "string"
    },
    "artemisId": {
      "format": "int64",
      "type": "integer"
    },
    "artemisUpdateDate": {
      "format": "date",
      "type": "string"
    },
    "id": {
      "format": "int64",
      "type": "integer"
    },
    "make": {
      "type": "string"
    },
    "manufacturer": {
      "$ref": "#/definitions/Manufacturer"
    },
    "model": {
      "type": "string"
    },
    "productCategory": {
      "enum": [
        "C",
        "E",
        "H",
        "L",
        "M",
        "T",
        "U",
        "Y"
      ],
      "type": "string"
    },
    "productType": {
      "enum": [
        "AT",
        "BS",
        "BT",
        "CD",
        "CO",
        "DB",
        "DT",
        "EV",
        "FT",
        "IC",
        "LB",
        "LT",
        "MP",
        "OT",
        "PC",
        "RI",
        "RT",
        "RV",
        "SB",
        "TB",
        "TK",
        "TT",
        "UNK",
        "UN",
        "VT",
        "FK"
      ],
      "type": "string"
    },
    "productValidation": {
      "enum": [
        "C",
        "M",
        "X"
      ],
      "type": "string"
    },
    "productYear": {
      "format": "int32",
      "type": "integer"
    },
    "source": {
      "type": "string"
    }
  },
  "type": "object"
}